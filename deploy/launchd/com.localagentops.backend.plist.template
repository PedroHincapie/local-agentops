<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Local AgentOps — LaunchAgent (macOS) para mantener el backend siempre arriba en :8787.
  NO edites este template a mano: usa deploy/launchd/install.sh, que sustituye los
  marcadores __PROJECT_DIR__ / __HOME__ y lo carga en ~/Library/LaunchAgents.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.localagentops.backend</string>

  <key>ProgramArguments</key>
  <array>
    <string>__PROJECT_DIR__/backend/.venv/bin/uvicorn</string>
    <string>app.main:app</string>
    <string>--host</string>
    <string>127.0.0.1</string>
    <string>--port</string>
    <string>8787</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__PROJECT_DIR__/backend</string>

  <!-- launchd no lee tu perfil de shell; damos un PATH con node/npx para ccusage. -->
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/local-agentops.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/local-agentops.log</string>
</dict>
</plist>
