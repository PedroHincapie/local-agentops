# Local AgentOps — backend config (copy to .env)
AGENTOPS_HOST=127.0.0.1
AGENTOPS_PORT=8787
AGENTOPS_DB_URL=sqlite:///./data/local-agentops.db

# Umbrales de estado (peak = max de las ventanas 5h/7d)
AGENTOPS_THRESHOLD_YELLOW=50
AGENTOPS_THRESHOLD_RED=80
AGENTOPS_THRESHOLD_CRITICAL=95

# Reconciliador (ccusage) — Hito 3
AGENTOPS_RECONCILE_INTERVAL_SECONDS=300

# SPA estática servida por el backend (si existe el build)
AGENTOPS_FRONTEND_DIST=../frontend/dist
