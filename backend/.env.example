# Local AgentOps — backend config (copy to .env)
AGENTOPS_HOST=127.0.0.1
AGENTOPS_PORT=8787
AGENTOPS_DB_URL=sqlite:///./data/local-agentops.db

# Umbrales de estado (peak = max de las ventanas 5h/7d)
AGENTOPS_THRESHOLD_YELLOW=50
AGENTOPS_THRESHOLD_RED=80
AGENTOPS_THRESHOLD_CRITICAL=95

# Reconciliador (ccusage) — Hito 3
AGENTOPS_RECONCILE_INTERVAL_SECONDS=300

# Cierre auto de sesión sin snapshots recientes (barrido proactivo del reconciliador)
AGENTOPS_SESSION_IDLE_MINUTES=120

# SPA/dashboard estático servido por el backend en / (mismo origen, sin CORS)
AGENTOPS_FRONTEND_DIST=../frontend/public

# CORS SOLO para desarrollo (dashboard abierto desde otro origen: archivo local o Vite).
# En operación normal el backend sirve el SPA en el mismo origen -> déjalo en false.
AGENTOPS_DEV_CORS=false
